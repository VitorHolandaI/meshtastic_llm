# Meshtastic LLM Gateway – environment variables template
# Copy this file to .env and fill in your values

# Serial port or TCP host for the Meshtastic device
# MESH_PORT=/dev/ttyUSB0
# MESH_HOST=192.168.1.10

# OpenVINO model directory
# MESH_MODEL=./qwen2.5-1.5b-instruct

# Compute device: CPU | GPU | NPU | AUTO
# MESH_DEVICE=CPU

# Reply mode: dm (only sender sees reply) | broadcast (all on channel 0 see reply)
# MESH_REPLY_MODE=dm

# Channel 0 PSK (Base64-encoded AES key).
# Must match the PSK configured on all Meshtastic devices.
# Default public key (factory default, no real privacy): AQ==
# Generate a private key: openssl rand -base64 32
MESH_CHANNEL_PSK=AQ==
